<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Шаблон ExportOptions для `flutter build ipa`. Используется в
  `.github/workflows/ios-release.yml` (подписанный TestFlight-билд).

  Перед сборкой workflow подставляет реальный Team ID через `sed`:
    sed -i '' "s/__TEAM_ID__/$APPLE_TEAM_ID/g" ios/ExportOptions.plist

  method=app-store — экспорт для App Store / TestFlight.
  signingStyle=manual — используем заранее установленный provisioning profile
  (apple-actions/import-codesign-certs + apple-actions/download-provisioning-profiles
  кладут .mobileprovision в ~/Library/MobileDevice/Provisioning Profiles/, а Xcode
  сам подхватывает его по bundle id).
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store</string>

    <key>teamID</key>
    <string>__TEAM_ID__</string>

    <key>signingStyle</key>
    <string>automatic</string>

    <key>uploadBitcode</key>
    <false/>

    <key>uploadSymbols</key>
    <true/>

    <key>compileBitcode</key>
    <false/>

    <key>stripSwiftSymbols</key>
    <true/>

    <key>destination</key>
    <string>export</string>
</dict>
</plist>
