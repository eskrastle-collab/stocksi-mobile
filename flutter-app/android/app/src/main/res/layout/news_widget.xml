<?xml version="1.0" encoding="utf-8"?>
<!--
  Виджет «Последние новости Stocksi». Размер 4×2 (≈250×110 dp).
  Шапка с лого + кнопка обновить, потом 3 карточки новостей.
  Все цвета — из палитры приложения (#1E2C39 фон, #B3C7DB текст).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="10dp">

    <!-- Header: title + refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="STOCKSI ULTIMATE"
            android:textColor="#B3C7DB"
            android:textSize="11sp"
            android:textStyle="normal"
            android:letterSpacing="0.1" />

        <ImageButton
            android:id="@+id/widget_refresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_popup_sync"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Обновить"
            android:tint="#62A1FF" />
    </LinearLayout>

    <!-- News slot 1 -->
    <LinearLayout
        android:id="@+id/news_slot_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_news_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/news_1_ticker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#62A1FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/news_1_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#A6BDD5"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/news_1_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E9F2"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Загрузка…" />
    </LinearLayout>

    <!-- News slot 2 -->
    <LinearLayout
        android:id="@+id/news_slot_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_news_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/news_2_ticker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#62A1FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/news_2_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#A6BDD5"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/news_2_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E9F2"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- News slot 3 -->
    <LinearLayout
        android:id="@+id/news_slot_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp"
        android:background="@drawable/widget_news_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/news_3_ticker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#62A1FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/news_3_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#A6BDD5"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/news_3_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E9F2"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
