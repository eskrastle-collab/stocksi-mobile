<?xml version="1.0" encoding="utf-8"?>
<!--
  Описание виджета для системы Android.
  - 4×2 (250×110 dp) — стандартный размер
  - Resizable по обеим осям
  - Update раз в 30 минут (минимум по Android API; реальные обновления
    мы пушим из самого приложения через HomeWidget.updateWidget())
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="180dp"
    android:targetCellWidth="4"
    android:targetCellHeight="3"
    android:initialLayout="@layout/news_widget"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:widgetFeatures="reconfigurable"
    android:updatePeriodMillis="1800000" />
